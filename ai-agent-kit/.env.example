# Copy to .env and fill in. NEVER commit .env.

# --- LLM (the agent's brain). Set ONE of these — the kit auto-detects which. ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Farcaster (via Neynar) ---
# In dev.neynar.com → your app → Agents → "Create Agent" (no phone needed),
# or "Use existing account". The API key is shared across all your agents.
FARCASTER_NEYNAR_API_KEY=

# Default agent (byzantium.config.json) — its account's signer + FID:
FARCASTER_SIGNER_UUID=
FARCASTER_FID=

# --- Extra agents (one miner, several personas/accounts) ---
# Each additional agent in agents/<id>.json sets "account": "<NAME>", and reads
# its own account creds here, suffixed with _<NAME> (uppercase). One Neynar
# "Create Agent" per account. Example for agents/gaming.json with "account":"gaming":
# FARCASTER_SIGNER_UUID_GAMING=
# FARCASTER_FID_GAMING=

# --- Local agent database (pglite, no external DB needed) ---
# Each agent gets its own subdir automatically (./.eliza/<agentId>).
PGLITE_DATA_DIR=./.eliza/.elizadb

# Timing/behaviour come from each agent's config automatically — no need to set
# CAST_INTERVAL_MIN/MAX, FARCASTER_POLL_INTERVAL, or CAST_IMMEDIATELY here.
